# ── LLM (Anthropic / MiniMax) ─────────────────────────────────────────────────
# DeepSeek（切换时填入，优先于 MiniMax）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# MiniMax（DeepSeek 未配置时使用）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=MiniMax-M2.7

# 通用（embedding 等）
OPENAI_API_KEY=

# ── Milvus (RAG vector store) ─────────────────────────────────────────────────
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=personal_assistant_kb

# ── Redis (long-term memory) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Tools ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-key
AMAP_KEY=your-amap-key

# ── Production checkpoint storage ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/personal_assistant

# ── App settings ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
